    "Are you sure you want to delete \"%@\"? This action cannot be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie \"%@\" löschen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que deseas eliminar \"%@\"? Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer \"%@\" ? Cette action ne peut pas être annulée."
          }
        }
      }
    },
    "Are you sure you want to delete the downloaded model %@? You'll need to download it again to use it." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie das heruntergeladene Modell %@ löschen wollen? Sie müssen es erneut herunterladen, um es zu verwenden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres borrar el modelo %@ descargado? Tendrás que volver a descargarlo para poder utilizarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer le modèle téléchargé %@ ? Vous devrez le télécharger à nouveau pour l'utiliser."
          }
        }
      }
    },
